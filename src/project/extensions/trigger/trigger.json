{
  "comment.saved": [
    {
      "handler": "sendSlack",
      "map": {
        "channel": "#notification-channel",
        "text": "🚀 새 댓글이 달렸어요! : {{data.content}}",
        "link": "/posts/{{data.document.module.mid}}/{{data.document.slug}}"
      }
    }
  ],
  "user.registered": [
    {
      "handler": "loggingUserAction",
      "map": {
        "message": "새로운 회원이 가입했습니다: {{data.nickName}}",
        "level": "info"
      }
    }
  ]
}