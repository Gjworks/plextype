{
  "name": "plextype",
  "version": "0.8.4",
  "private": true,
  "scripts": {
    "setup": "node setup.mjs",
    "dev": "dotenv -e .env.development next dev --turbo --port 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "release": "release-it",
    "deploy": "npm version patch && git push origin main --follow-tags",
    "migrate:dev": "dotenv -e .env.development -- npx prisma migrate dev",
    "migrate:reset": "dotenv -e .env.development -- npx prisma migrate reset",
    "migrate:init": "dotenv -e .env.development -- npx prisma migrate dev --name init",
    "dbpush:push": "dotenv -e .env.development -- npx prisma db push"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@prisma/client": "^6.19.2",
    "@tailwindcss/cli": "^4.0.13",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.68.0",
    "@tiptap/extension-highlight": "^3.16.0",
    "@tiptap/extension-image": "^3.16.0",
    "@tiptap/extension-link": "^3.16.0",
    "@tiptap/extension-placeholder": "^3.16.0",
    "@tiptap/extension-table": "^3.16.0",
    "@tiptap/extension-table-cell": "^3.16.0",
    "@tiptap/extension-table-header": "^3.16.0",
    "@tiptap/extension-table-row": "^3.16.0",
    "@tiptap/extension-text-align": "^3.16.0",
    "@tiptap/extension-underline": "^3.16.0",
    "@tiptap/html": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "@types/crypto-js": "^4.2.2",
    "axios": "^1.1.3",
    "bcrypt": "^6.0.0",
    "dayjs": "^1.11.13",
    "dotenv-cli": "^8.0.0",
    "framer-motion": "^12.5.0",
    "isomorphic-dompurify": "^2.35.0",
    "jose": "^6.0.9",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.562.0",
    "mime-types": "^3.0.1",
    "nanoid": "^5.1.9",
    "next": "^16.2.4",
    "prismjs": "^1.29.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.0",
    "relative-time": "^1.0.0",
    "shiki": "^3.23.0",
    "systeminformation": "^5.31.5",
    "tiptap-extension-code-block-shiki": "^1.1.0",
    "uuid": "^13.0.0",
    "v8": "^0.1.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "release-it": "^19.2.4",
