{
  "github": {
    "release": true
  },
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}",
    "requireCleanWorkingDir": true
  },
  "hooks": {
    "after:bump": "npx auto-changelog -p"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md",
      "header": "# 📋 변경 이력 (Change Log)\n\n"
    }
  }
}